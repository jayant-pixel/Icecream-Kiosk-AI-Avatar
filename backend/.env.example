PORT=8080

# HeyGen configuration
HEYGEN_API_KEY=your_heygen_api_key_here
HEYGEN_BASE_URL=https://api.heygen.com
HEYGEN_AVATAR_ID=your_streaming_avatar_id

# OpenAI configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_ASSISTANT_ID=your_assistant_id
OPENAI_ASSISTANT_MODEL=gpt-4o-mini

# Optional webhook integrations
PRODUCTS_WEBHOOK_URL=
CHECKOUT_WEBHOOK_URL=
DIRECTIONS_WEBHOOK_URL=

# Optional: allow additional origins during local development (comma separated)
CORS_ALLOWED_ORIGINS=http://localhost:5173
