import express from "express";
import fetch from "node-fetch";
import multer from "multer";
import dotenv from "dotenv";
import { OpenAI } from "openai";
dotenv.config();
const app = express();
app.use(express.json());
// ---- config & clients ----
const HEYGEN_API = process.env.HEYGEN_BASE_URL || "https://api.heygen.com";
const HEYGEN_KEY = process.env.HEYGEN_API_KEY;
const OPENAI_KEY = process.env.OPENAI_API_KEY;
if (!HEYGEN_KEY) throw new Error("Missing HEYGEN_API_KEY");
if (!OPENAI_KEY) throw new Error("Missing OPENAI_API_KEY");
const openai = new OpenAI({ apiKey: OPENAI_KEY });
/**
* 1) Create HeyGen v3 session (HeyGen-managed LiveKit)
* v1/v2 are deprecated; pass version:"v3" and avatar_id. (Docs: v1/v2 no longer
supported)
*/
app.post("/api/session/new", async (req, res) => {
try {
const { avatarId, language = "en", quality = "high" } = req.body || {};
const r = await fetch(`${HEYGEN_API}/v1/streaming.new`, {
method: "POST",
headers: { "x-api-key": HEYGEN_KEY!, "Content-Type": "application/json" },
body: JSON.stringify({
avatar_id: avatarId,
version: "v3", // REQUIRED: v1/v2 deprecated
language,
quality,
voice_mode: false, // custom STT + tool flow (we speak via streaming.task)
voice_auto_start: false
}),
});
const data = await r.json();
if (!r.ok || !data?.data) return res.status(500).json({ error: data });
const { session_id, livekit_url, access_token } = data.data;
res.json({ sessionId: session_id, livekitUrl: livekit_url, accessToken: access_token });
} catch (e:any) {
res.status(500).json({ error: e?.message || "session.new failed" });
}
});
/**
* 2) Speak via avatar (text -> TTS + video)
* Proxy so the browser never holds HEYGEN_KEY.
*/
app.post("/api/avatar/speak", async (req, res) => {
try {
const { sessionId, text } = req.body || {};
const r = await fetch(`${HEYGEN_API}/v1/streaming.task`, {
method: "POST",
headers: { "x-api-key": HEYGEN_KEY!, "Content-Type": "application/json" },
body: JSON.stringify({ session_id: sessionId, task_type: "talk", text }),
});
const data = await r.json();
if (!r.ok) return res.status(500).json({ error: data });
res.json({ ok: true });
} catch (e:any) {
res.status(500).json({ error: e?.message || "speak failed" });
}
});
/**
* 3) STT — OpenAI Whisper transcription
* Accepts audio via multipart/form-data: field "audio" = Blob (webm/wav/mp3).
* Returns text transcript.
*/
const upload = multer({ storage: multer.memoryStorage() });
app.post("/api/stt/transcribe", upload.single("audio"), async (req, res) => {
try {
if (!req.file) return res.status(400).json({ error: "missing audio" });
// Whisper model: "whisper-1" (OpenAI Speech-to-Text guide)
const transcript = await openai.audio.transcriptions.create({
file: new File([req.file.buffer], req.file.originalname || "input.webm", { type:
req.file.mimetype }),
model: "whisper-1"
});
res.json({ text: transcript.text });
} catch (e:any) {
res.status(500).json({ error: e?.message || "stt failed" });
}
});
/**
* 4) LLM Brain — function calling for tools
* Tools:
* - find_products(query)
* - add_to_cart(product_id, qty)
* - checkout(cart)
* - directions(bin)
* This demo uses simple in-memory stubs. Replace with your DB/services.
*/
type CartItem = { id: string; qty: number; price_cents: number };
const PRODUCTS = [
{ id: "p1", name: "Chocolate Cone", price_cents: 12000, image_url: "/img/choc_cone.png",
bin: "FZ-A2-B4" },
{ id: "p2", name: "Vanilla Cup", price_cents: 9000, image_url: "/img/vanilla_cup.png", bin:
"FZ-B1-A1" },
{ id: "p3", name: "Strawberry Tub", price_cents: 18000, image_url: "/img/straw_tub.png",
bin: "FZ-A2-C2" },
];
function findProducts(query:string){
const q = query.toLowerCase();
return PRODUCTS.filter(p => p.name.toLowerCase().includes(q) || (q.includes("chocolate")
&& p.id==="p1"));
}
function addToCart(cart:CartItem[], product_id:string, qty:number){
const prod = PRODUCTS.find(p=>p.id===product_id) || PRODUCTS[0];
const idx = cart.findIndex(li=>li.id===prod.id);
if (idx>=0) cart[idx].qty += qty; else cart.push({ id: prod.id, qty, price_cents: prod.price_cents
});
return cart;
}
function checkout(cart:CartItem[]){
const subtotal = cart.reduce((s, li)=> s + li.price_cents*li.qty, 0);
const tax = Math.round(subtotal * 0.05);
const total = subtotal + tax;
return { subtotal, tax, total };
}
function getDirections(bin:string){
return { display_name: "Freezer Aisle 2, Bin 4", steps: ["Walk straight 5m","Turn left"], bin,
map_svg_url: "/map/store.svg" };
}
app.post("/api/brain/respond", async (req, res) => {
try {
const { utterance, cart=[] } = req.body || {};
const tools = [
{
type: "function",
function: {
name: "find_products",
description: "Search ice-cream catalog by a natural language query.",
parameters: { type: "object", properties: { query: { type:"string" } }, required: ["query"] }
}
},
{
type: "function",
function: {
name: "add_to_cart",
description: "Add a product to the cart with quantity.",
parameters: { type:"object", properties:{ product_id:{type:"string"}, qty:{type:"integer"} },
required:["product_id","qty"] }
}
},
{
type: "function",
function: {
name: "checkout",
description: "Compute totals for the current cart.",
parameters: { type:"object", properties:{ cart:{type:"array", items:{type:"object"}}},
required:["cart"] }
}
},
{
type: "function",
function: {
name: "get_directions",
description: "Get pickup directions for a product bin code.",
parameters: { type:"object", properties:{ bin:{type:"string"} }, required:["bin"] }
}
}
];
// Use a current chat model that supports function calling.
const resp = await openai.chat.completions.create({
model: "gpt-4o-mini", // fast, tool-capable; adjust as needed
messages: [
{ role: "system", content: "You are a kiosk assistant for an ice-cream shop. Be brief and
helpful." },
{ role: "user", content: utterance }
],
tools
});
const choice = resp.choices[0];
const toolCall = choice?.message?.tool_calls?.[0];
if (toolCall) {
const { name, arguments: argsJson } = toolCall.function;
const args = JSON.parse(argsJson || "{}");
if (name === "find_products") {
const items = findProducts(args.query || "");
// Return an overlay instruction to the client + a short line to speak
return res.json({ type: "show_products", products: items, response: "Here are some
options I found." });
}
if (name === "add_to_cart") {
const updated = addToCart(cart, args.product_id, args.qty || 1);
return res.json({ type: "add_to_cart", productId: args.product_id, qty: args.qty || 1, cart:
updated, response: "Added to your cart. Anything else?" });
}
if (name === "checkout") {
const totals = checkout(cart);
return res.json({ type: "checkout", receipt: totals, response: `Your total is
₹${(totals.total/100).toFixed(2)}. Would you like anything else?` });
}
if (name === "get_directions") {
const info = getDirections(args.bin || "FZ-A2-B4");
return res.json({ type: "directions", directions: info, response: `Please head to
${info.display_name}.` });
}
}
// No tool call → small talk fallback
return res.json({ type: "chat", response: choice.message.content || "How can I help you
choose ice-cream?" });
} catch (e:any) {
res.status(500).json({ error: e?.message || "brain failed" });
}
});
/**
* 5) (Same safe stubs as before) Direct endpoints you may keep if the frontend calls them
directly.
*/
app.post("/api/nlp/interpret", (req, res) => {
// Keep for backwards-compat, but /api/brain/respond supersedes it.
res.json({ type: "chat", response: "Use /api/brain/respond for intent + tools." });
});
app.get("/api/catalog/search", (req, res) => {
const q = (req.query.q as string || "").toLowerCase();
res.json({ results: PRODUCTS.filter(p => p.name.toLowerCase().includes(q)) });
});
app.post("/api/order/checkout", (req, res) => {
const cart: CartItem[] = req.body?.cart || [];
const totals = checkout(cart);
res.json({ receipt: totals, receipt_url: "/receipt/123" });
});
app.get("/api/directions/for-pickup", (req, res) => {
const bin = (req.query.bin as string) || "FZ-A2-B4";
res.json(getDirections(bin));
});
const PORT = process.env.PORT || 8080;
app.listen(PORT, () => console.log(`Backend listening on ${PORT}`));
