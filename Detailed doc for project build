});
/**
* 7) Forward to Make.com "Create Order" scenario.
* Called during checkout.
*/
app.post("/api/make/order", async (req, res) => {
try {
const { cart, total } = req.body || {};
const r = await fetch(MAKE_ORDER_HOOK!, {
method: "POST",
headers: { "Content-Type": "application/json" },
body: JSON.stringify({ cart, total }),
});
const data = await r.json();
res.json(data);
} catch (e:any) {
res.status(500).json({ error: e.message || "make order failed"
});
}
});
3. Update the “brain” function calls
Inside the /api/brain/respond endpoint from Part 1, replace the local
findProducts() and checkout() with Make webhook calls:
// replace findProducts()
async function findProductsViaMake(query:string) {
const r = await fetch(`${process.env.LOCAL_URL ||
"http://localhost:8080"}/api/make/products`, {
method: "POST",
headers: { "Content-Type": "application/json" },
body: JSON.stringify({ query })
});
const data = await r.json();
return data.products || [];
}
// replace checkout()
async function checkoutViaMake(cart:CartItem[]) {
const r = await fetch(`${process.env.LOCAL_URL ||
"http://localhost:8080"}/api/make/order`, {
method: "POST",
headers: { "Content-Type": "application/json" },
body: JSON.stringify({ cart, total: cart.reduce((s,
c)=>s+c.price_cents*c.qty, 0) })
});
const data = await r.json();
return data.receipt || { subtotal:0, tax:0, total:0 };
}
Then, in the tool-call logic, call these async helpers:
if (name === "find_products") {
const items = await findProductsViaMake(args.query || "");
return res.json({ type:"show_products", products: items,
response:"Here are some options I found." });
}
if (name === "checkout") {
const totals = await checkoutViaMake(cart);
return res.json({ type:"checkout", receipt: totals, response:`Your
total is ₹${(totals.total/100).toFixed(2)}. Would you like anything
else?` });
}
All other tools stay the same.
