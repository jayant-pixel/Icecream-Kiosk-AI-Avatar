setCart((c) => {
const idx = c.findIndex(li => li.id === id);
if (idx >= 0) {
const copy = [...c];
copy[idx].qty += 1;
return copy;
}
return [...c, { id, qty:1, price_cents:price }];
});
};
const onClose = () => setOverlay(null);
window.addEventListener("add-to-cart", onAdd);
window.addEventListener("close-overlay", onClose);
return () => {
window.removeEventListener("add-to-cart", onAdd);
window.removeEventListener("close-overlay", onClose);
};
}, []);
const handleUtterance = useCallback(async (text:string) => {
if (!session) return;
try {
const intent = await brainRespond(text, cart);
// Speak first
await speak(session.sessionId, intent.response || "Okay!");
// Then show overlay if needed
if (intent.type === "show_products") {
setOverlay({ type:"products", data: intent.products });
} else if (intent.type === "directions") {
setOverlay({ type:"directions", data: intent.directions });
} else if (intent.type === "add_to_cart") {
setCart(intent.cart);
setOverlay(null); // Hide products overlay after add
} else if (intent.type === "checkout") {
// you could navigate to a ReceiptOverlay, for now just hide
overlay
setOverlay(null);
} else {
// chat fallback
setOverlay(null);
}
} catch (e) {
console.error("brain error", e);
await speak(session.sessionId, "I’m sorry — something went
wrong. Please try again.");
}
}, [session, cart]);
const startSession = useCallback(async () => {
try {
const s = await newSession(avatarId);
setSession(s);
setStarted(true);
// greet
setTimeout(() => {
speak(s.sessionId, "Hi! Welcome to Scoop Haven. How can I
help you today?");
}, 500);
} catch (e) {
console.error("session start error", e);
alert("Session failed. Please restart.");
}
}, []);
return (
<div className="relative w-screen h-screen bg-black text-white
overflow-hidden">
{!started ? (
<Hero onStart={startSession} />
) : session ? (
<>
<AvatarStream session={session} avatarId={avatarId}
onReady={() => {}} />
<OverlayManager overlay={overlay} />
<div className="absolute bottom-6 left-1/2
-translate-x-1/2 w-3/4 max-w-3xl">
<MicBar onUtterance={handleUtterance} />
</div>
</>
) : (
<div className="flex items-center justify-center h-full">
<p>Loading…</p>
</div>
)}
</div>
);
}
