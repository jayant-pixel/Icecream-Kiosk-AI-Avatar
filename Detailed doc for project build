4) lib/stt.ts – Microphone capture for Whisper STT
Create frontend/src/lib/stt.ts:
// frontend/src/lib/stt.ts
export async function captureAudio(seconds = 3): Promise<Blob> {
const stream = await navigator.mediaDevices.getUserMedia({ audio:
true });
const recorder = new MediaRecorder(stream, { mimeType:
"audio/webm" });
const chunks: BlobPart[] = [];
recorder.ondataavailable = (e) => {
if (e.data.size > 0) {
chunks.push(e.data);
}
};
recorder.start();
await new Promise((r) => setTimeout(r, seconds * 1000));
recorder.stop();
await new Promise((r) => {
recorder.onstop = () => r(undefined);
});
stream.getTracks().forEach((t) => t.stop());
return new Blob(chunks, { type: "audio/webm" });
}
Explanation:
● We request mic access (getUserMedia).
● Record for a set time (default 3 seconds).
● Return a Blob suitable for sending to /api/stt/transcribe.
● For kiosk use you may replace this with push-to-talk UI (not automatic continuous
recording) to reduce errors.
