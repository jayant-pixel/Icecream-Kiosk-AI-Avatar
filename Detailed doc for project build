Create frontend/src/components/MicBar.tsx:
// frontend/src/components/MicBar.tsx
import React, { useState } from "react";
import { captureAudio } from "../lib/stt";
type MicBarProps = { onUtterance: (text: string) => void };
export function MicBar({ onUtterance }: MicBarProps) {
const [busy, setBusy] = useState(false);
const handleSpeak = async () => {
try {
setBusy(true);
const blob = await captureAudio(3); // record 3 seconds
const transcript = await fetch("/api/stt/transcribe", {
method: "POST",
body: blob,
}).then((r) => r.json()).then((j) => j.text);
if (transcript) onUtterance(transcript);
} catch (e) {
console.error("STT error", e);
alert("Audio capture failed. Please try again.");
} finally {
setBusy(false);
}
};
return (
<div className="flex gap-2 items-center">
<button
onClick={handleSpeak}
disabled={busy}
className="px-6 py-3 rounded-xl bg-purple-600 text-white
hover:bg-purple-500 disabled:opacity-50"
>
{busy ? "Listening…" : "Hold to Talk"}
</button>
<input
type="text"
placeholder="Or type here"
className="flex-1 px-3 py-2 rounded-xl border"
onKeyDown={(e) => {
if (e.key === "Enter") onUtterance((e.target as
HTMLInputElement).value);
}}
/>
</div>
);
}
Note: This sends recorded audio blob to /api/stt/transcribe. You could integrate with
